# SPA routing: every request that isn't a real file/dir goes through the PHP
# front controller (index.php), which injects per-route SEO metadata and serves
# the React shell. Static assets (assets/, media/, *.webp, …) are served directly.
DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.php [QSA,L]
</IfModule>
