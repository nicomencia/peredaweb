  },
  {
    "id": "9ac1f290-a199-4928-a9b9-753005844b04",
    "key": "cta_1_label",
    "value": "PIDE CITA",
    "updated_at": "2026-06-09T09:39:32.9+00:00"
  },
  {
    "id": "0a5e1cf2-f9e9-4a86-b1d9-d6534b8f6ba5",
    "key": "cta_1_description",
    "value": "Te ofrecemos la posibilidad de solicitar cita previa antes de acudir a nuestro establecimiento, podrás beneficiarte de una atención personalizada en tus proyectos de reformas y además evitar tiempos de espera.",
    "updated_at": "2026-06-09T09:39:32.968+00:00"
  },
  {
    "id": "d2103ed7-ceb2-4c7f-a5b9-41dea728eee3",
