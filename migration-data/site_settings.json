  },
  {
    "id": "b9ecc334-c8ec-43ab-95c9-f3bd7584643a",
    "key": "area_benefits_subtitle",
    "value": "Porque aquí encuentras calidad al mejor precio, un amplio stock con primeras marcas, el mejor asesoramiento personalizado y, además, todas las novedades y ofertas al alcance de tu mano.",
    "updated_at": "2026-05-31T15:52:52.766571+00:00"
  },
